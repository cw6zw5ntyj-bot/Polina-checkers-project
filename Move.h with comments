#pragma once
#include <stdlib.h>
//тип координаты клетки на доске(0-7)
typedef int8_t POS_T;
//структура для хранения одного хода
struct move_pos
{
    POS_T x, y;             // from // начальная клетка
    POS_T x2, y2;           // to //конечная  клетка
    POS_T xb = -1, yb = -1; // beaten //координаты съеденной фигуры(если есть)
    //конструктор для обычного хода без взятия
    move_pos(const POS_T x, const POS_T y, const POS_T x2, const POS_T y2) : x(x), y(y), x2(x2), y2(y2)
    {
    }
    //конструктор для хода с взятием
    move_pos(const POS_T x, const POS_T y, const POS_T x2, const POS_T y2, const POS_T xb, const POS_T yb)
        : x(x), y(y), x2(x2), y2(y2), xb(xb), yb(yb)
    {
    }
   // сравнение двух ходов (без учёта единой фигуры)
    bool operator==(const move_pos &other) const
    {
        return (x == other.x && y == other.y && x2 == other.x2 && y2 == other.y2);
    }
    //обратное сравнение
    bool operator!=(const move_pos &other) const
    {
        return !(*this == other);
    }
};
